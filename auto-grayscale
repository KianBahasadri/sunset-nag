#!/usr/bin/env python3
"""auto-grayscale: fade the GNOME (Wayland) screen to grayscale around sunset and
back to color around sunrise.

Grayscale is achieved with GNOME's accessibility magnifier at 1x zoom, varying
color-saturation between 1.0 (full color) and 0.0 (full grayscale). The
saturation follows a linear ramp over a transition window centered on sunset and
sunrise, so the change is gradual rather than instant. No external packages are
needed: sunrise/sunset are computed locally with the standard sunrise equation.

Subcommands:
  daemon   Run continuously, adjusting saturation over time (used by the service).
  apply    Set the correct saturation for "now" once, then exit.
  on       Force full grayscale now.
  off      Force full color now.
  status   Print today's sun times, transition windows, and current state.
  times    Print today's sunrise and sunset.

The daemon steps every few seconds while inside a transition window (for a smooth
fade) and sleeps until the next window otherwise. All changes are idempotent.
"""

import math
import subprocess
import sys
import time
from datetime import datetime, timedelta, timezone

# ---------------------------------------------------------------------------
# Configuration -- edit these for your location.
# Latitude is north-positive, longitude is east-positive.
# Toronto, ON:
LAT = 43.6532
LON = -79.3832
# Sun altitude (degrees) that counts as sunrise/sunset. -0.833 is the standard
# value (sun's upper limb at the horizon, accounting for refraction).
# Use -6 for civil twilight if you want the switch a bit later/earlier.
SUN_ALTITUDE = -0.833
# Length of the fade, in minutes. The ramp is centered on the event, so with 15
# the fade runs from 7.5 min before sunset to 7.5 min after (and likewise for
# sunrise). To instead start the fade exactly at the event, see ANCHOR below.
TRANSITION_MINUTES = 15
# Where the transition sits relative to the event:
#   "center" -> [event - T/2, event + T/2]   (50% gray exactly at sunset)
#   "start"  -> [event, event + T]           (full color at sunset, gray after)
#   "end"    -> [event - T, event]           (fully gray exactly at sunset)
ANCHOR = "center"
# ---------------------------------------------------------------------------

# Daemon timing.
STEP_SECONDS = 5            # update interval while fading
MAX_IDLE_SECONDS = 60       # longest sleep when not fading

MAGNIFIER = "org.gnome.desktop.a11y.magnifier"
A11Y_APPS = "org.gnome.desktop.a11y.applications"


def sun_times(lat, lon, year, month, day):
    """Return (sunrise, sunset) as timezone-aware UTC datetimes for the given
    calendar date, or (None, None) if the sun does not rise/set that day.

    Based on the sunrise equation (https://en.wikipedia.org/wiki/Sunrise_equation),
    accurate to roughly a minute -- far better than needed here.
    """
    # Julian Day Number for the Gregorian date (integer, refers to noon UTC).
    a = (14 - month) // 12
    y = year + 4800 - a
    m = month + 12 * a - 3
    jdn = (
        day
        + (153 * m + 2) // 5
        + 365 * y
        + y // 4
        - y // 100
        + y // 400
        - 32045
    )

    n = jdn - 2451545 + 0.0008          # days since 2000-01-01 12:00 (+ leap corr.)
    j_star = n - lon / 360.0            # mean solar time (lon east-positive)

    M = (357.5291 + 0.98560028 * j_star) % 360          # solar mean anomaly
    Mr = math.radians(M)
    C = 1.9148 * math.sin(Mr) + 0.0200 * math.sin(2 * Mr) + 0.0003 * math.sin(3 * Mr)
    lam = (M + C + 180 + 102.9372) % 360                # ecliptic longitude
    lamr = math.radians(lam)

    j_transit = 2451545.0 + j_star + 0.0053 * math.sin(Mr) - 0.0069 * math.sin(2 * lamr)

    sin_d = math.sin(lamr) * math.sin(math.radians(23.4397))   # solar declination
    cos_d = math.cos(math.asin(sin_d))

    latr = math.radians(lat)
    cos_w = (
        math.sin(math.radians(SUN_ALTITUDE)) - math.sin(latr) * sin_d
    ) / (math.cos(latr) * cos_d)
    if cos_w > 1:
        return None, None       # sun never rises (polar night)
    if cos_w < -1:
        return None, None       # sun never sets (polar day)
    w = math.degrees(math.acos(cos_w))

    def jd_to_dt(jd):
        unix = (jd - 2440587.5) * 86400.0
        return datetime.fromtimestamp(unix, tz=timezone.utc)

    return jd_to_dt(j_transit - w / 360.0), jd_to_dt(j_transit + w / 360.0)


def sun_times_for(local_date):
    return sun_times(LAT, LON, local_date.year, local_date.month, local_date.day)


def todays_sun_times():
    """(sunrise, sunset) UTC datetimes for the current *local* date."""
    return sun_times_for(datetime.now().astimezone().date())


def _window(event):
    """(start, end) of the transition window around an event time."""
    T = timedelta(minutes=TRANSITION_MINUTES)
    if ANCHOR == "start":
        return event, event + T
    if ANCHOR == "end":
        return event - T, event
    return event - T / 2, event + T / 2     # "center"


def _clamp(x, lo=0.0, hi=1.0):
    return max(lo, min(hi, x))


def is_night(now, sunrise, sunset):
    """True outside the daytime band (before sunrise or after sunset)."""
    return now < sunrise or now >= sunset


def target_saturation(now=None):
    """Desired color-saturation (1.0 full color, 0.0 grayscale) for `now`,
    interpolated across the sunset/sunrise transition windows."""
    if now is None:
        now = datetime.now(timezone.utc)
    sunrise, sunset = todays_sun_times()
    if sunrise is None or sunset is None:
        return 1.0      # polar edge case: leave color alone

    rise_start, rise_end = _window(sunrise)
    set_start, set_end = _window(sunset)

    if set_start <= now <= set_end:                 # fading to grayscale
        frac = (now - set_start) / (set_end - set_start)
        return _clamp(1.0 - frac)
    if rise_start <= now <= rise_end:               # fading back to color
        frac = (now - rise_start) / (rise_end - rise_start)
        return _clamp(frac)
    return 0.0 if is_night(now, sunrise, sunset) else 1.0


def in_transition(now=None):
    if now is None:
        now = datetime.now(timezone.utc)
    sunrise, sunset = todays_sun_times()
    if sunrise is None or sunset is None:
        return False
    for event in (sunrise, sunset):
        start, end = _window(event)
        if start <= now <= end:
            return True
    return False


def seconds_until_next_window(now=None):
    """Seconds until the next transition window starts (today or tomorrow)."""
    if now is None:
        now = datetime.now(timezone.utc)
    today = datetime.now().astimezone().date()
    starts = []
    for off in (0, 1):
        sr, ss = sun_times_for(today + timedelta(days=off))
        if sr and ss:
            starts += [_window(sr)[0], _window(ss)[0]]
    future = [s for s in starts if s > now]
    return (min(future) - now).total_seconds() if future else MAX_IDLE_SECONDS


# --- gsettings plumbing -----------------------------------------------------

def _gset(schema, key, value):
    subprocess.run(["gsettings", "set", schema, key, value], check=True)


def _gget(schema, key):
    return subprocess.run(
        ["gsettings", "get", schema, key],
        check=True, capture_output=True, text=True,
    ).stdout.strip()


def magnifier_enabled():
    try:
        return _gget(A11Y_APPS, "screen-magnifier-enabled") == "true"
    except subprocess.CalledProcessError:
        return False


def current_saturation():
    try:
        return float(_gget(MAGNIFIER, "color-saturation"))
    except (subprocess.CalledProcessError, ValueError):
        return 1.0


def apply_saturation(sat):
    """Idempotently make the screen show the given saturation. The magnifier is
    only enabled while saturation < 1.0; it is enabled/disabled at saturation
    ~1.0 so that turning it on/off is itself imperceptible."""
    sat = _clamp(sat)
    enabled = magnifier_enabled()

    if sat >= 0.999:                                # full color -> magnifier off
        if enabled:
            _gset(MAGNIFIER, "color-saturation", "1.0")
            _gset(A11Y_APPS, "screen-magnifier-enabled", "false")
        return

    target = round(sat, 3)
    if not enabled:
        # 1x zoom, whole screen, no lens -> no magnification, only desaturation.
        _gset(MAGNIFIER, "mag-factor", "1.0")
        _gset(MAGNIFIER, "lens-mode", "false")
        _gset(MAGNIFIER, "screen-position", "'full-screen'")
        _gset(MAGNIFIER, "color-saturation", str(target))
        _gset(A11Y_APPS, "screen-magnifier-enabled", "true")
    elif round(current_saturation(), 3) != target:
        _gset(MAGNIFIER, "color-saturation", str(target))


# --- commands ---------------------------------------------------------------

def cmd_daemon():
    print("auto-grayscale daemon started "
          f"(transition {TRANSITION_MINUTES} min, anchor {ANCHOR})", flush=True)
    while True:
        now = datetime.now(timezone.utc)
        try:
            apply_saturation(target_saturation(now))
        except (subprocess.CalledProcessError, FileNotFoundError) as e:
            print(f"skipped: gsettings not reachable ({e})", flush=True)
        if in_transition(now):
            sleep = STEP_SECONDS
        else:
            sleep = _clamp(seconds_until_next_window(now), STEP_SECONDS, MAX_IDLE_SECONDS)
        time.sleep(sleep)


def cmd_apply():
    sat = target_saturation()
    try:
        apply_saturation(sat)
        print(f"saturation set to {round(sat, 3)}")
    except (subprocess.CalledProcessError, FileNotFoundError) as e:
        print(f"skipped: gsettings not reachable ({e})")


def _fmt(dt):
    return "n/a" if dt is None else dt.astimezone().strftime("%-I:%M %p")


def cmd_status():
    sunrise, sunset = todays_sun_times()
    print(f"location:    {LAT}, {LON}")
    print(f"sunrise:     {_fmt(sunrise)}")
    print(f"sunset:      {_fmt(sunset)}")
    if sunrise and sunset:
        rs, re_ = _window(sunrise)
        ss, se = _window(sunset)
        print(f"to-color:    {_fmt(rs)} -> {_fmt(re_)}  (fade {TRANSITION_MINUTES} min)")
        print(f"to-gray:     {_fmt(ss)} -> {_fmt(se)}  (fade {TRANSITION_MINUTES} min)")
    print(f"now:         {datetime.now().astimezone().strftime('%-I:%M %p')}")
    print(f"in fade:     {'yes' if in_transition() else 'no'}")
    print(f"target sat:  {round(target_saturation(), 3)}")
    print(f"current sat: {round(current_saturation(), 3)} "
          f"(magnifier {'on' if magnifier_enabled() else 'off'})")


def cmd_times():
    sunrise, sunset = todays_sun_times()
    print(f"sunrise {_fmt(sunrise)}  sunset {_fmt(sunset)}")


def main(argv):
    cmd = argv[1] if len(argv) > 1 else "status"
    if cmd == "daemon":
        cmd_daemon()
    elif cmd == "apply":
        cmd_apply()
    elif cmd == "on":
        apply_saturation(0.0)
        print("grayscale on")
    elif cmd == "off":
        apply_saturation(1.0)
        print("grayscale off")
    elif cmd == "status":
        cmd_status()
    elif cmd == "times":
        cmd_times()
    else:
        print(__doc__)
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
