[Unit]
Description=auto-grayscale: fade screen to grayscale around sunset/sunrise
After=graphical-session.target
PartOf=graphical-session.target

# NOTE: install.sh writes the real unit into ~/.config/systemd/user/ with the
# ExecStart path filled in to wherever this repo lives. This file is a template
# for reference.

[Service]
Type=simple
ExecStart=%h/auto-grayscale/auto-grayscale daemon
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
