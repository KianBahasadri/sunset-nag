# Copy to .env (install.sh does this on first install). Edit .env to override
# script defaults without changing auto-grayscale itself. The daemon re-reads
# this file every few seconds, so changes take effect while the service runs.

# Set to false (or 0/no/off) to keep full color even with the service running.
ENABLED=true

# Location (latitude north-positive, longitude east-positive).
LAT=43.6532
LON=-79.3832

# Sun altitude (degrees) for sunrise/sunset. -0.833 is standard; -6 is civil twilight.
SUN_ALTITUDE=-0.833

# Fade length in minutes.
TRANSITION_MINUTES=15

# Transition anchor: center | start | end
ANCHOR=center