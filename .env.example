# Copy to .env (install.sh does this on first install). Edit .env to override
# script defaults without changing sunset-nag itself. The daemon re-reads this
# file every loop, so changes take effect live without a restart.

# Set to false (or 0/no/off) to keep full color even with the service running.
ENABLED=true

# Location (latitude north-positive, longitude east-positive).
LAT=43.6532
LON=-79.3832

# Sun altitude (degrees) for sunrise/sunset. -0.833 is standard; -6 is civil
# twilight (a few minutes later at sunset, earlier at sunrise).
SUN_ALTITUDE=-0.833

# Night Light temperature ramp (Kelvin). Lower = warmer / more orange.
# START_TEMPERATURE is applied at sunset; each Snooze ramps by TEMP_STEP towards
# END_TEMPERATURE.
START_TEMPERATURE=4000
END_TEMPERATURE=1800
TEMP_STEP=200

# Notification cadence.
# SNOOZE_MINUTES: minutes to pause before the next nag after you Snooze or
# dismiss the dialog. Each Snooze shrinks the next pause by 1 minute (floor 1),
# so the nagging speeds up the longer you stay up.
SNOOZE_MINUTES=5
