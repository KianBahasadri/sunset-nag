    "bed.",
    "You know what? I'm not even mad. I'm impressed. Still though. Bed.",
]


def send_nag_notification(temp_k, snooze_count=0, snooze_minutes=None):
    """Show a modal GNOME dialog with Snooze + Emergency buttons.

    Returns "snooze" or "emergency" depending on which button was clicked,
    or "" if the dialog was closed/timed out/errored.
    """
    if snooze_minutes is None:
        snooze_minutes = SNOOZE_MINUTES
    msg = NAG_MESSAGES[min(snooze_count, len(NAG_MESSAGES) - 1)]
    text = msg
    if snooze_count > 0:
        text += f"\n\nYou've snoozed {snooze_count} time{'s' if snooze_count != 1 else ''}."

    cmd = [
        "zenity",
        "--warning",
        "--title", "sunset-nag",
        "--text", text,
        "--ok-label", f"Snooze {snooze_minutes} min",
        "--extra-button", "It\u2019s an emergency",
        "--width", "400",
    ]

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""

    out = result.stdout.strip()
    if "emergency" in out.lower():
        return "emergency"
    if result.returncode == 0:
        return "snooze"
    return ""


# ---------------------------------------------------------------------------
# Formatting helpers.
# ---------------------------------------------------------------------------

def _fmt(dt):
    return "n/a" if dt is None else dt.astimezone().strftime("%-I:%M %p")


# ---------------------------------------------------------------------------
# Commands.
# ---------------------------------------------------------------------------

def cmd_daemon():
    load_env()
    print(f"sunset-nag daemon started "
          f"(ramp {START_TEMPERATURE}\u2192{END_TEMPERATURE}K, "
          f"step -{TEMP_STEP}, "
          f"nag every {NAG_INTERVAL} min, snooze {SNOOZE_MINUTES} min, "
          f"enabled {'yes' if ENABLED else 'no'})", flush=True)

    # If a previous run left a saved state (e.g., after a crash), restore it
    # first so we don't treat a ramped screen as the user's original settings.
    if STATE_PATH.is_file():
        _restore_state()
    # Persist current Night Light settings so we can restore on exit.
    _save_state()

    stop = {"flag": False}
    def _handle_exit(*_):
        stop["flag"] = True
    signal.signal(signal.SIGTERM, _handle_exit)
    signal.signal(signal.SIGINT, _handle_exit)

    try:
        # Track whether we have an active nag window. Initialized by the first
        # loop iteration; preserved across sleep-wake so the logic detects both
        # the sunset->active and active->sunrise transitions.
        nag_start_sunset = None   # the sunset event that started the current nag
        nag_end_sunrise = None    # the sunrise that will end it

        snoozed_until = None
        current_temp_k = START_TEMPERATURE
        nag_disabled = False      # emergency: suppress nags until sunrise
        snooze_count = 0          # times snoozed this nag period
        current_snooze = SNOOZE_MINUTES  # snooze pause shrinks by 1 per snooze, min 1

        while not stop["flag"]:
            load_env()
            now_utc = datetime.now(timezone.utc)
            now_local = datetime.now().astimezone()

            try:
                sunset, sunrise = _compute_night_window(
                    now_utc, now_local.date()
                )
            except Exception:
                sunset, sunrise = None, None

            if sunset is None or sunrise is None:
                # Polar case or transient failure -- sleep and retry.
                time.sleep(60)
                continue

            # Determine transitions:
            entered = nag_start_sunset is None and now_utc >= sunset
            left = nag_start_sunset is not None and now_utc >= nag_end_sunrise

            if entered:
                nag_start_sunset = sunset
                nag_end_sunrise = sunrise
                # Always prime the ramp start regardless of ENABLED, so a
                # later mid-evening ENABLED toggle still begins from
                # START_TEMPERATURE.
                current_temp_k = START_TEMPERATURE
                if ENABLED:
                    configure_night_light_schedule()
                    set_temperature(current_temp_k)
                    print(f"sunset nag started (sunset was {_fmt(sunset)})",
                          flush=True)

            elif left:
                _restore_state()
                ensure_gsd_color()
                nag_start_sunset = None
                nag_end_sunrise = None
                snoozed_until = None
                nag_disabled = False
                snooze_count = 0
                current_snooze = SNOOZE_MINUTES
                print(f"sunrise -- nag ended ({_fmt(sunrise)})", flush=True)

            # Active nag period.
            if ENABLED and nag_start_sunset is not None and \
               now_utc < nag_end_sunrise and not nag_disabled:
                ensure_gsd_color()

                if snoozed_until is not None and datetime.now() < snoozed_until:
                    time.sleep(DAEMON_SLEEP)
                    continue

                print(f"nag: {current_temp_k}K", flush=True)
                action = send_nag_notification(
                    current_temp_k, snooze_count, current_snooze
                )

                if action == "snooze":
                    snooze_count += 1
                    snoozed_for = current_snooze
                    snoozed_until = datetime.now() + \
                        timedelta(minutes=current_snooze)
                    current_snooze = max(1, current_snooze - 1)
                    current_temp_k = max(
                        END_TEMPERATURE, current_temp_k - TEMP_STEP
                    )
                    set_temperature(current_temp_k)
                    print(f"snoozed: ramping to {current_temp_k}K, "
                          f"pausing {snoozed_for} min", flush=True)
                elif action == "emergency":
                    _restore_state(delete=False)
                    try:
                        _set_key("night-light-enabled", "false")
                    except subprocess.CalledProcessError:
                        pass
                    # Keep the nag window marked active (do NOT null
                    # nag_start_sunset): nulling it makes the `entered`
                    # transition re-fire while it is still night and call
                    # configure_night_light_schedule(), which re-enables
                    # Night Light seconds later. Suppress nags until
                    # sunrise with nag_disabled instead.
                    nag_disabled = True
                    snoozed_until = None
                    print("emergency -- Night Light disabled until sunrise",
                          flush=True)
                    time.sleep(DAEMON_SLEEP)
                    continue
                else:
                    snoozed_until = datetime.now() + timedelta(minutes=current_snooze)
                    print("dismissed -- pausing {0} min".format(current_snooze), flush=True)
                # timeout/error: ignore, will re-nag next cycle

                time.sleep(DAEMON_SLEEP)
                continue

            # Idle: sleep until near the next sunset, but cap at 60s so we
            # notice config changes and clock shifts in reasonable time.
            idle_sleep = min(60, max(5, int((sunset - now_utc).total_seconds())))
            time.sleep(idle_sleep)

    finally:
        _restore_state()
        print("sunset-nag daemon stopped; Night Light restored.", flush=True)


def cmd_status():
    load_env()
    sunrise, sunset = todays_sun_times()
    env_note = f" ({ENV_PATH})" if ENV_PATH.is_file() else ""
    state_note = ""
    if STATE_PATH.is_file():
        try:
            state = json.loads(STATE_PATH.read_text())
            state_note = (" (saved restore: enabled="
                          f"{state.get('night-light-enabled')}, "
                          f"temp={state.get('night-light-temperature')}K)")
        except json.JSONDecodeError:
            state_note = " (saved state: corrupted)"

    print(f"enabled:        {'yes' if ENABLED else 'no'}{env_note}{state_note}")
    print(f"location:       {LAT}, {LON}")
    print(f"sunrise:        {_fmt(sunrise)}")
    print(f"sunset:         {_fmt(sunset)}")
    print(f"now:            {datetime.now().astimezone().strftime('%-I:%M %p')}")

    try:
        cur_temp = get_temperature()
        nl_on = night_light_enabled()
        print(f"current temp:   {cur_temp}K (Night Light {'on' if nl_on else 'off'})")
    except subprocess.CalledProcessError:
        print("current temp:   (unreadable)")

    print(f"start temp:     {START_TEMPERATURE}K")
    print(f"end temp:       {END_TEMPERATURE}K")
    print(f"step:           -{TEMP_STEP}K per Snooze")
    print(f"nag interval:   {NAG_INTERVAL} min")
    print(f"snooze pause:   {SNOOZE_MINUTES} min")


def cmd_times():
    load_env()
    sunrise, sunset = todays_sun_times()
    print(f"sunrise {_fmt(sunrise)}  sunset {_fmt(sunset)}")


def cmd_test():
    """Immediate ramp + nag for testing (does not wait for sunset)."""
    load_env()
    _save_state()
    print(f"test: setting Night Light to {START_TEMPERATURE}K")
    configure_night_light_schedule()
    set_temperature(START_TEMPERATURE)
    ensure_gsd_color()
    print("notification sent -- click Snooze or It's an emergency")

    action = send_nag_notification(START_TEMPERATURE, 0)
    if action == "snooze":
        new_temp = max(END_TEMPERATURE, START_TEMPERATURE - TEMP_STEP)
        set_temperature(new_temp)
        print(f"snoozed -- ramping to {new_temp}K, pausing {SNOOZE_MINUTES} min")
        time.sleep(3)
    elif action == "emergency":
        print("emergency -- would disable Night Light for the night")
        time.sleep(3)
    else:
        print("no action (timeout/error)")
        time.sleep(3)

    print("restoring...")
    _restore_state(delete=False)
    print("done.")


def cmd_on():
    load_env()
    _save_state()
    configure_night_light_schedule()
    set_temperature(END_TEMPERATURE)
    ensure_gsd_color()
    print(f"Night Light forced to {END_TEMPERATURE}K.")
    print("Run 'sunset-nag off' to restore your previous settings.")


def cmd_off():
    _restore_state()
    try:
        _set_key("night-light-enabled", "false")
    except subprocess.CalledProcessError as e:
        print(f"could not disable: {e}")
        return 1
    print("Night Light disabled.")
    return 0


def main(argv):
    cmd = argv[1] if len(argv) > 1 else "status"
    handlers = {
        "daemon": cmd_daemon,
        "status": cmd_status,
        "times": cmd_times,
        "test": cmd_test,
        "on": cmd_on,
        "off": cmd_off,
    }
    if cmd not in handlers:
        print(__doc__)
        return 2
    return handlers[cmd]() or 0


load_env()

if __name__ == "__main__":
    sys.exit(main(sys.argv))
