# Notification.
# ---------------------------------------------------------------------------

NAG_MESSAGES = [
    "It's bedtime.",
    "Seriously, go to bed.",
    "You're still here? Go to sleep.",
    "Okay, this is getting ridiculous. Bed. Now.",
    "Why are you still awake? What are you even doing?",
    "This is not a negotiation. Turn off the screen.",
    "I'm not asking again. Well, I am, but I shouldn't have to.",
    "Every minute you stay up, the screen gets worse. You know this.",
    "Fine. Keep snoozing. See how that works out for you.",
    "Your future self is begging you to stop. For real.",
    "I give up. You win. But you're going to feel this tomorrow.",
    "...",
    "You're really testing the limits of this nag, aren't you?",
    "Go. To. Sleep.",
    "Last warning. After this it's just going to be this screen at 1800K forever.",
    "No but seriously, please go to bed. I'm worried about you.",
    "This is the longest anyone has ever snoozed. You should be proud. You shouldn't be awake though.",
